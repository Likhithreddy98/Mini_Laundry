{
  "info": {
    "name": "Mini Laundry System",
    "description": "API endpoints for the Mini Laundry Order system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Test Admin\",\n    \"email\": \"admin@laundry.com\",\n    \"password\": \"SecurePass123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@laundry.com\",\n    \"password\": \"SecurePass123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer YOUR_JWT_TOKEN" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"customerName\": \"Aman Singh\",\n    \"phone\": \"9876543210\",\n    \"garmentType\": \"Shirt\",\n    \"quantity\": 3\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/orders",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "orders"]
            }
          }
        },
        {
          "name": "Get All Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer YOUR_JWT_TOKEN" }
            ],
            "url": {
              "raw": "http://localhost:5000/api/orders",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "orders"]
            }
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer YOUR_JWT_TOKEN" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"PROCESSING\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/orders/ORD-ID-HERE/status",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "orders", "ORD-ID-HERE", "status"]
            }
          }
        },
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer YOUR_JWT_TOKEN" }
            ],
            "url": {
              "raw": "http://localhost:5000/api/orders/dashboard",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "orders", "dashboard"]
            }
          }
        }
      ]
    }
  ]
}
